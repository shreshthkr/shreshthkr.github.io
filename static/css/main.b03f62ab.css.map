.about_section{
    width: 100%;
    height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #1A2238;
}
.container{
    width: 60%;
    height: 60%;
    display: flex;
    justify-content: space-around;
    align-items: center;
  
}
#info{
    width: 47%;
    height: 80%;
    display: flex;
    flex-direction: column;
    align-items: left;
    justify-content: space-around;
    text-align: left;
    line-height: 15px;
    color: #F4DB7D;
   
}
h1{
    font-weight: 500;
}
p{
    line-height: 25px;
}
#pic{
    width: 250px;
    height: 250px;
}
.home-img{
    width: 100%;
    height: 100%;
    border-radius: 45%;
}
