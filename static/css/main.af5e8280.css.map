*{
    background-color: #1A2238;  
}
.about-me{
    width:15%;
    height: 60px;
    display: flex;
    justify-content: center;
    align-items: center;
    margin: auto;
    text-align: center;
    color: #F4DB7D;
    background-color: #1A2238; 
    border: 2px solid #F4DB7D ;
    border-style: dotted;
    border-radius: 10px;
}
.about-me h1{
    font-size: 35px;

}
.about-intro{
    width: 100%;
    height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10%;
    flex-wrap: wrap;
}
.picture{
    width: 21%;
    height: 66%;
    border-radius: 50%;
    box-shadow: #fff 0px 0px 15px;
}
.picture .home-img{
    width: 100%;
    height: 100%;
    border-radius: 50%;
    cursor: pointer;
}
.details{
    width: 40%;
    height: 40%; 
}
.details h3{

    font-weight: 500;
    color: #F4DB7D;
}
.details p{
    margin-top: 10px;
    line-height: 22px;
    font-size: 18px;
    font-weight: 400;
    color:#fff ;
}
.mern{
    position: relative;
    top: 50%;  
    width: 24em;
    margin: 0 auto;
    border-right: 2px solid rgba(255,255,255,.75);
    font-size: 180%;
    text-align: center;
    white-space: nowrap;
    overflow: hidden;
    transform: translateY(-50%)
}

@media (max-width: 940px){
    .about-me{
        width: 60%;
        margin: auto;
        height: auto;
        margin-bottom: 20px;
    }
    .about-intro{
        width: 100%;
        height: auto;
       display: flex;
       flex-direction: column; 
    }
    .details{
        text-align: center;
    }
}